class Solution {
    public int maxPathSum(int[] a, int[] b) {
        int i = 0, j = 0;
        int m = a.length, n = b.length;
        
        long sumA = 0, sumB = 0;
        long totalMaxSum = 0;
        
        // Traverse both arrays simultaneously
        while (i < m && j < n) {
            if (a[i] < b[j]) {
                sumA += a[i++];
            } else if (b[j] < a[i]) {
                sumB += b[j++];
            } else { 
                // Found a common element (intersection point)
                // Add the maximum sum accumulated so far plus the common element
                totalMaxSum += Math.max(sumA, sumB) + a[i];
                
                // Reset running sums for the next segment
                sumA = 0;
                sumB = 0;
                i++;
                j++;
            }
        }
        
        // Collect remaining elements of array a, if any
        while (i < m) {
            sumA += a[i++];
        }
        
        // Collect remaining elements of array b, if any
        while (j < n) {
            sumB += b[j++];
        }
        
        // Add the maximum of the final remaining segments
        totalMaxSum += Math.max(sumA, sumB);
        
        return (int) totalMaxSum;
    }
}
