import java.util.*;

class Node {
    int val;
    Node next;
    Node(int x) { val = x; next = null; }
}

public class Main {
    public static Node buildLinkedList(int size, int[] elements) {
        if (size == 0) return null;
        Node head = new Node(elements[0]);
        Node tail = head;
        for (int i = 1; i < size; i++) {
            tail.next = new Node(elements[i]);
            tail = tail.next;
        }
        return head;
    }

    public static int pairSum(Node head) {
        if (head == null) return 0;

        // Step 1: Find the middle of the linked list using fast & slow pointers
        Node slow = head;
        Node fast = head;
        while (fast != null && fast.next != null) {
            slow = slow.next;
            fast = fast.next.next;
        }

        // Step 2: Reverse the second half of the linked list
        Node prev = null;
        Node curr = slow;
        while (curr != null) {
            Node nextNode = curr.next;
            curr.next = prev;
            prev = curr;
            curr = nextNode;
        }

        // Step 3: Compute the symmetric pair sums
        int maxPairSum = Integer.MIN_VALUE;
        Node firstHalfPointer = head;
        Node secondHalfPointer = prev; // 'prev' is the head of the reversed second half

        while (secondHalfPointer != null) {
            int currentSum = firstHalfPointer.val + secondHalfPointer.val;
            maxPairSum = Math.max(maxPairSum, currentSum);
            
            firstHalfPointer = firstHalfPointer.next;
            secondHalfPointer = secondHalfPointer.next;
        }

        return maxPairSum;
    }

    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        if (!scanner.hasNextInt()) return;
        int n = scanner.nextInt(); 
        int[] elements = new int[n]; 
        for (int i = 0; i < n; i++) {
            elements[i] = scanner.nextInt();
        }
        Node head = buildLinkedList(n, elements);
        int result = pairSum(head);
        System.out.println(result);
    }
}
