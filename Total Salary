import java.util.Scanner;

class Solution {
    
    public static void main(String args[]) {
        Scanner sc = new Scanner(System.in);
        
        if (sc.hasNextInt()) {
            int basic = sc.nextInt();
            char grade = sc.next().charAt(0);
            
            // Calculate components as floating-point numbers to preserve precision
            double hra = 0.20 * basic;
            double da = 0.50 * basic;
            double pf = 0.11 * basic;
            
            // Determine allowance based on grade
            int allow = 1300; // Default for 'C' or any other character
            if (grade == 'A') {
                allow = 1700;
            } else if (grade == 'B') {
                allow = 1500;
            }
            
            // Calculate total salary
            double totalSalary = basic + hra + da + allow - pf;
            
            // Round to nearest integer and print the integral part
            long roundedSalary = Math.round(totalSalary);
            System.out.println(roundedSalary);
        }
        
        sc.close();
    }
}
