import java.util.Scanner;

public class Main {
    public static int user_logic(int l, int r) {
        // Base case: If there's only one number, or no room for two distinct numbers
        if (l == r) {
            return 0;
        }

        // Calculate the ideal divisor that would maximize the remainder of r
        int idealB = (r / 2) + 1;

        // If our ideal divisor falls within the [l, r] boundary
        if (idealB >= l) {
            return r % idealB;
        } else {
            // Otherwise, the best we can do is dividing the largest by the smallest
            return r % l;
        }
    }

    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        if (scanner.hasNextInt()) {
            int t = scanner.nextInt();
            for (int i = 0; i < t; i++) {
                int l = scanner.nextInt();
                int r = scanner.nextInt();
                
                int result = user_logic(l, r);
                System.out.println(result);
            }
        }
        scanner.close();
    }
}
