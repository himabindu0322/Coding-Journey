import java.util.*;

public class Main {
    public static int userLogic(int n, List<int[]> positionsCards) {
        List<int[]> left = new ArrayList<>();
        List<int[]> right = new ArrayList<>();

        // Separate positions into left and right groups
        for (int[] pc : positionsCards) {
            if (pc[0] < 0) {
                left.add(pc);
            } else if (pc[0] > 0) {
                right.add(pc);
            }
        }

        // Sort left points by coordinate descending (closer to 0 first, e.g., -1, -2, -5)
        Collections.sort(left, (a, b) -> Integer.compare(b[0], a[0]));
        
        // Sort right points by coordinate ascending (closer to 0 first, e.g., 1, 2, 5)
        Collections.sort(right, (a, b) -> Integer.compare(a[0], b[0]));

        int lSize = left.size();
        int rSize = right.size();
        int totalCards = 0;

        // Determine how many elements we can take from each side
        if (lSize == rSize) {
            // Take all elements from both sides
            for (int[] pc : left) totalCards += pc[1];
            for (int[] pc : right) totalCards += pc[1];
        } else if (lSize > rSize) {
            // Right is smaller, take all from right, and rSize + 1 from left
            for (int[] pc : right) totalCards += pc[1];
            for (int i = 0; i < rSize + 1; i++) {
                totalCards += left.get(i)[1];
            }
        } else {
            // Left is smaller, take all from left, and lSize + 1 from right
            for (int[] pc : left) totalCards += pc[1];
            for (int i = 0; i < lSize + 1; i++) {
                totalCards += right.get(i)[1];
            }
        }

        return totalCards;
    }

    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        if (!scanner.hasNextInt()) return;
        
        int n = scanner.nextInt();
        List<int[]> positionsCards = new ArrayList<>();
        for (int i = 0; i < n; i++) {
            int pi = scanner.nextInt();
            int ci = scanner.nextInt();
            positionsCards.add(new int[]{pi, ci});
        }
        int result = userLogic(n, positionsCards);
        System.out.println(result);
    }
}
