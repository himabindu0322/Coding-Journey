import java.util.Arrays;
import java.util.PriorityQueue;

public class Solution {
    public static int scheduleCourse(int[][] courses) {
        // Step 1: Sort courses by their deadlines (lastDay)
        Arrays.sort(courses, (a, b) -> Integer.compare(a[1], b[1]));

        // Step 2: Max-Heap to track the durations of chosen courses
        PriorityQueue<Integer> maxHeap = new PriorityQueue<>((a, b) -> Integer.compare(b, a));
        
        int time = 0; // Tracks the current total time elapsed

        // Step 3: Iterate through each sorted course
        for (int[] course : courses) {
            int duration = course[0];
            int lastDay = course[1];

            // Add the current course to our schedule
            time += duration;
            maxHeap.offer(duration);

            // If the total time exceeds the deadline, evict the longest course taken so far
            if (time > lastDay) {
                time -= maxHeap.poll();
            }
        }

        // The size of the max-heap represents the maximum number of courses we can take
        return maxHeap.size();
    }
}
