import java.util.*;
import java.io.*;
import java.util.ArrayList;

public class Solution {
    public static int robotSim(ArrayList<Integer> commands, int[][] obstacles) {
        // Store obstacles in a HashSet for O(1) lookup
        HashSet<String> obstacleSet = new HashSet<>();
        for (int[] obs : obstacles) {
            obstacleSet.add(obs[0] + "," + obs[1]);
        }

        // Direction arrays representing: North, East, South, West (Clockwise order)
        int[] dx = {0, 1, 0, -1};
        int[] dy = {1, 0, -1, 0};

        // Robot state tracking variables
        int x = 0, y = 0;
        int dir = 0; // Starts facing North (idx 0)
        int maxDistSq = 0;

        for (int cmd : commands) {
            if (cmd == -1) {
                // Turn right 90 degrees clockwise
                dir = (dir + 1) % 4;
            } else if (cmd == -2) {
                // Turn left 90 degrees counter-clockwise
                dir = (dir + 3) % 4;
            } else {
                // Move forward 'cmd' steps
                for (int step = 0; step < cmd; step++) {
                    int nextX = x + dx[dir];
                    int nextY = y + dy[dir];

                    // Check if the next cell contains an obstacle
                    if (obstacleSet.contains(nextX + "," + nextY)) {
                        break; // Stop moving along this command direction
                    }

                    // Confirm the position update
                    x = nextX;
                    y = nextY;

                    // Compute maximum Euclidean distance squared
                    maxDistSq = Math.max(maxDistSq, x * x + y * y);
                }
            }
        }

        return maxDistSq;
    }
}
