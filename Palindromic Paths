import java.util.*;

class TreeNode {
    int val;
    TreeNode left;
    TreeNode right;
    TreeNode(int x) { val = x; left = null; right = null; }
}

public class Main {

    public static TreeNode makeTree(int idx, int n, int[] arr) {
        if (idx >= n || arr[idx] == -1) {
            return null;
        }
        TreeNode root = new TreeNode(arr[idx]);
        root.left = makeTree(2 * idx + 1, n, arr);
        root.right = makeTree(2 * idx + 2, n, arr);
        return root;
    }

    public static int countPalindromicPaths(TreeNode root) {
        // Start DFS tracking the parity mask initialized to 0
        return dfs(root, 0);
    }

    private static int dfs(TreeNode node, int mask) {
        if (node == null) {
            return 0;
        }

        // Toggle the bit corresponding to the current node's value
        mask ^= (1 << node.val);

        // If it's a leaf node, check if the mask contains at most one set bit
        if (node.left == null && node.right == null) {
            return ((mask & (mask - 1)) == 0) ? 1 : 0;
        }

        // Recursively find paths in both left and right subtrees
        int leftPaths = dfs(node.left, mask);
        int rightPaths = dfs(node.right, mask);

        return leftPaths + rightPaths;
    }

    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        if (!scanner.hasNextInt()) return;
        
        int n = scanner.nextInt();
        int[] arr = new int[n];
        for (int i = 0; i < n; i++) {
            arr[i] = scanner.nextInt();
        }
        TreeNode root = makeTree(0, n, arr);
        int result = countPalindromicPaths(root);
        System.out.println(result);
    }
}
