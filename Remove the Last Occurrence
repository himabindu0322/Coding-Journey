import java.util.*;

class ListNode {
    int val;
    ListNode next;
    ListNode(int x) { val = x; next = null; }
}

public class Main {
    public static ListNode removeLastOccurrences(ListNode head) {
        if (head == null) return null;

        // Map to keep track of the node reference of the last occurrence of each value
        Map<Integer, ListNode> lastOccurrences = new HashMap<>();

        // Step 1: Record the last occurrence node for each value
        ListNode current = head;
        while (current != null) {
            lastOccurrences.put(current.val, current);
            current = current.next;
        }

        // Step 2: Reconstruct the list by skipping all recorded last occurrence nodes
        ListNode dummy = new ListNode(0);
        ListNode tail = dummy;
        current = head;

        while (current != null) {
            // If the current node is the exact reference of the last occurrence, skip it
            if (lastOccurrences.get(current.val) == current) {
                current = current.next;
            } else {
                // Link it to our new filtered chain
                tail.next = current;
                tail = tail.next;
                current = current.next;
            }
        }
        
        // Terminate the modified list properly to avoid hanging old references
        tail.next = null; 

        return dummy.next;
    }

    public static void printLinkedList(ListNode head) {
        ListNode current = head;
        while (current != null) {
            System.out.print(current.val + " ");
            current = current.next;
        }
        System.out.println();
    }

    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        if (!scanner.hasNextLine()) return;
        
        int n = Integer.parseInt(scanner.nextLine().trim());
        if (n == 0) {
            System.out.println();
            return;
        }

        String line = scanner.nextLine().trim();
        if (line.isEmpty()) {
            System.out.println();
            return;
        }
        
        String[] values = line.split("\\s+");
        ListNode head = new ListNode(Integer.parseInt(values[0]));
        ListNode current = head;
        for (int i = 1; i < n && i < values.length; i++) {
            current.next = new ListNode(Integer.parseInt(values[i]));
            current = current.next;
        }

        // Call user logic function
        ListNode modified_head = removeLastOccurrences(head);

        // Print the modified linked list
        printLinkedList(modified_head);
    }
}
