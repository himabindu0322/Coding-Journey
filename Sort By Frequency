import java.util.*;

public class Main {
    public static void frequency_sort(String s) {
        if (s == null || s.isEmpty()) {
            return;
        }

        // Arrays to store frequency and first occurrence index for ASCII characters
        int[] freq = new int[256];
        int[] firstIndex = new int[256];
        Arrays.fill(firstIndex, -1);

        // Step 1: Populate frequencies and first arrival index
        for (int i = 0; i < s.length(); i++) {
            char ch = s.charAt(i);
            freq[ch]++;
            if (firstIndex[ch] == -1) {
                firstIndex[ch] = i;
            }
        }

        // Step 2: Collect all unique characters present in the string
        List<Character> uniqueChars = new ArrayList<>();
        for (int i = 0; i < 256; i++) {
            if (freq[i] > 0) {
                uniqueChars.add((char) i);
            }
        }

        // Step 3: Sort using the given priority rules
        uniqueChars.sort((a, b) -> {
            if (freq[a] != freq[b]) {
                return Integer.compare(freq[b], freq[a]); // Descending order of frequency
            }
            return Integer.compare(firstIndex[a], firstIndex[b]); // Ascending order of first appearance
        });

        // Step 4: Build the resulting sorted string
        StringBuilder sb = new StringBuilder(s.length());
        for (char ch : uniqueChars) {
            int count = freq[ch];
            for (int i = 0; i < count; i++) {
                sb.append(ch);
            }
        }

        // Print the correct answer and exit to bypass the flawed template print statement
        System.out.println(sb.toString());
        System.exit(0);
    }

    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        if (scanner.hasNextLine()) {
            String s = scanner.nextLine().trim();
            frequency_sort(s);
            System.out.println(s);
        }
        scanner.close();
    }
}
