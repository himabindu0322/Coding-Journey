import java.util.Arrays;

class Solution {
    public int removeCoveredIntervals(int[][] intervals) {
        // Step 1: Sort intervals
        // Ascending by start point; if start points are equal, descending by end point.
        Arrays.sort(intervals, (a, b) -> {
            if (a[0] == b[0]) {
                return b[1] - a[1];
            }
            return a[0] - b[0];
        });

        int remainingCount = 0;
        int maxEnd = 0;

        // Step 2: Iterate through the sorted intervals
        for (int[] interval : intervals) {
            int currentEnd = interval[1];
            
            // If the current interval's end extends further than maxEnd,
            // it is NOT covered by any previous interval.
            if (currentEnd > maxEnd) {
                remainingCount++;
                maxEnd = currentEnd; // Update the boundary
            }
            // If currentEnd <= maxEnd, it is covered, so we just skip it.
        }

        return remainingCount;
    }
}
