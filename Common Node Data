import java.io.*;
import java.util.*;

class Node {
    int data;
    Node next;
    Node(int data) {
        this.data = data;
        this.next = null;
    }
}

public class Main {

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        if (!sc.hasNextInt()) return;

        int n1 = sc.nextInt();
        int n2 = sc.nextInt();

        int[] arr1 = new int[n1];
        for (int i = 0; i < n1; i++) {
            arr1[i] = sc.nextInt();
        }

        int[] arr2 = new int[n2];
        for (int i = 0; i < n2; i++) {
            arr2[i] = sc.nextInt();
        }

        // To perfectly model the condition "all subsequent nodes are also the same",
        // we can link the shared suffix nodes together dynamically from the rear.
        int i = n1 - 1;
        int j = n2 - 1;

        Node commonTail = null;
        // Find how many elements match strictly from the end
        while (i >= 0 && j >= 0 && arr1[i] == arr2[j]) {
            Node newNode = new Node(arr1[i]);
            newNode.next = commonTail;
            commonTail = newNode;
            i--;
            j--;
        }

        // Build the remaining unique prefix for List 1
        Node head1 = commonTail;
        for (int k = i; k >= 0; k--) {
            Node newNode = new Node(arr1[k]);
            newNode.next = head1;
            head1 = newNode;
        }

        // Build the remaining unique prefix for List 2
        Node head2 = commonTail;
        for (int k = j; k >= 0; k--) {
            Node newNode = new Node(arr2[k]);
            newNode.next = head2;
            head2 = newNode;
        }

        // Find the intersection node using two pointers
        int result = findIntersection(head1, head2);
        System.out.println(result);
    }

    private static int findIntersection(Node head1, Node head2) {
        if (head1 == null || head2 == null) return -1;

        Node ptr1 = head1;
        Node ptr2 = head2;

        // Loop runs until an intersection is met or both pointers hit null concurrently
        while (ptr1 != ptr2) {
            ptr1 = (ptr1 == null) ? head2 : ptr1.next;
            ptr2 = (ptr2 == null) ? head1 : ptr2.next;
        }

        // If they intersect, ptr1 will contain the intersection node. Otherwise null.
        return (ptr1 != null) ? ptr1.data : -1;
    }
}
