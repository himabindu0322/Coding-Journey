import java.util.*;

class Main {
    // Custom ListNode for our Hash Map chaining
    static class Node {
        int key;
        int value;
        Node next;
        
        Node(int key, int value) {
            this.key = key;
            this.value = value;
        }
    }

    public static List<Integer> processQueries(List<Tuple> queries) {
        List<Integer> results = new ArrayList<>();
        
        // Use a fixed bucket array size (a prime number minimizes collisions)
        int BUCKETS = 20011;
        Node[] table = new Node[BUCKETS];
        
        for (Tuple query : queries) {
            int index = Math.abs(query.key) % BUCKETS;
            
            if (query.type == 1) {
                // --- INSERT / UPDATE ---
                if (table[index] == null) {
                    table[index] = new Node(query.key, query.value);
                } else {
                    Node curr = table[index];
                    boolean found = false;
                    while (curr != null) {
                        if (curr.key == query.key) {
                            curr.value = query.value; // Update existing key
                            found = true;
                            break;
                        }
                        if (curr.next == null) break;
                        curr = curr.next;
                    }
                    if (!found) {
                        curr.next = new Node(query.key, query.value); // Attach to tail
                    }
                }
                
            } else if (query.type == 2) {
                // --- GET ---
                Node curr = table[index];
                int foundValue = -1;
                while (curr != null) {
                    if (curr.key == query.key) {
                        foundValue = curr.value;
                        break;
                    }
                    curr = curr.next;
                }
                results.add(foundValue);
                
            } else if (query.type == 3) {
                // --- DELETE ---
                Node curr = table[index];
                Node prev = null;
                
                while (curr != null) {
                    if (curr.key == query.key) {
                        if (prev == null) {
                            table[index] = curr.next; // Remove head node
                        } else {
                            prev.next = curr.next; // Bypass middle/tail node
                        }
                        break;
                    }
                    prev = curr;
                    curr = curr.next;
                }
            }
        }
        
        return results;
    }

    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        if (!scanner.hasNextInt()) return;
        
        int n = scanner.nextInt();
        List<Tuple> queries = new ArrayList<>();
        for (int i = 0; i < n; i++) {
            int queryType = scanner.nextInt();
            if (queryType == 1) {
                int key = scanner.nextInt();
                int value = scanner.nextInt();
                queries.add(new Tuple(1, key, value));
            } else if (queryType == 2) {
                int key = scanner.nextInt();
                queries.add(new Tuple(2, key, 0));
            } else if (queryType == 3) {
                int key = scanner.nextInt();
                queries.add(new Tuple(3, key, 0));
            }
        }
        
        List<Integer> results = processQueries(queries);
        for (int result : results) {
            System.out.println(result);
        }
    }

    static class Tuple {
        int type, key, value;
        Tuple(int type, int key, int value) {
            this.type = type;
            this.key = key;
            this.value = value;
        }
    }
}
