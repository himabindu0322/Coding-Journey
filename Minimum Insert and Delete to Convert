import java.util.*;

class Solution {
    public int minInsAndDel(int[] a, int[] b) {
        int n = a.length;
        int m = b.length;
        
        // Since b is sorted and distinct, we can use binary search to find elements quickly
        List<Integer> filteredIndices = new ArrayList<>();
        
        for (int x : a) {
            int idx = Arrays.binarySearch(b, x);
            // If the element from 'a' exists in 'b', store its index position in 'b'
            if (idx >= 0) {
                filteredIndices.add(idx);
            }
        }
        
        // Find the Length of the Longest Increasing Subsequence (LIS) of the filtered indices
        int lisLength = findLIS(filteredIndices);
        
        // Total operations = (Deletions from a) + (Insertions into a)
        return (n - lisLength) + (m - lisLength);
    }
    
    // O(N log N) patience sorting / binary search approach for LIS
    private int findLIS(List<Integer> list) {
        if (list.isEmpty()) return 0;
        
        List<Integer> tails = new ArrayList<>();
        
        for (int x : list) {
            int idx = Collections.binarySearch(tails, x);
            
            // If element is not found, binarySearch returns (-(insertion point) - 1)
            if (idx < 0) {
                idx = -(idx + 1);
            }
            
            if (idx == tails.size()) {
                tails.add(x);
            } else {
                tails.set(idx, x);
            }
        }
        
        return tails.size();
    }
}
