import java.util.*;
import java.io.*;

public class Solution {
    public static String numFollowingPattern(String s) {
        if (s == null || s.length() == 0) {
            return "";
        }

        StringBuilder result = new StringBuilder();
        Stack<Integer> stack = new Stack<>();
        int n = s.length();

        // We need to process N + 1 digits (from 1 to N + 1)
        for (int i = 0; i <= n; i++) {
            // Push the current digit (1-indexed) into the stack
            stack.push(i + 1);

            // If we hit an 'I' or reached the end of the pattern string
            if (i == n || s.charAt(i) == 'I') {
                // Flush the stack into the result string
                while (!stack.isEmpty()) {
                    result.append(stack.pop());
                }
            }
        }

        return result.toString();
    }
}
