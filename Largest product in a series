import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
        Scanner in = new Scanner(System.in);
        if (in.hasNextInt()) {
            int t = in.nextInt();
            for (int a0 = 0; a0 < t; a0++) {
                int n = in.nextInt();
                int k = in.nextInt();
                String num = in.next();
                
                long maxProduct = 0;
                
                // Slide a window of size K across the string
                for (int i = 0; i <= n - k; i++) {
                    long currentProduct = 1;
                    
                    // Multiply K consecutive digits
                    for (int j = 0; j < k; j++) {
                        int digit = num.charAt(i + j) - '0';
                        currentProduct *= digit;
                    }
                    
                    // Keep track of the highest product found
                    if (currentProduct > maxProduct) {
                        maxProduct = currentProduct;
                    }
                }
                
                System.out.println(maxProduct);
            }
        }
        in.close();
    }
}
