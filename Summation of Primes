import java.io.*;
import java.util.*;

public class Solution {

    // Define the maximum limit based on the problem constraints (N <= 10^6)
    private static final int MAX = 1000000;
    private static long[] primeSums = new long[MAX + 1];

    public static void precomputePrimes() {
        boolean[] isPrime = new boolean[MAX + 1];
        Arrays.fill(isPrime, true);
        isPrime[0] = false;
        isPrime[1] = false;

        // Step 1: Standard Sieve of Eratosthenes
        for (int p = 2; p * p <= MAX; p++) {
            if (isPrime[p]) {
                for (int i = p * p; i <= MAX; i += p) {
                    isPrime[i] = false;
                }
            }
        }

        // Step 2: Build Prefix Sum Array
        long currentSum = 0;
        for (int i = 0; i <= MAX; i++) {
            if (isPrime[i]) {
                currentSum += i;
            }
            primeSums[i] = currentSum;
        }
    }

    public static void main(String[] args) {
        // Precompute everything once before processing any test cases
        precomputePrimes();

        Scanner in = new Scanner(System.in);
        if (in.hasNextInt()) {
            int t = in.nextInt();
            for (int a0 = 0; a0 < t; a0++) {
                int n = in.nextInt();
                // O(1) lookup
                System.out.println(primeSums[n]);
            }
        }
        in.close();
    }
}
