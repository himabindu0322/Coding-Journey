import java.util.Arrays;

class Solution {
    public int maxCharGap(String s) {
        // Array to store the first occurrence index of each character ('a' to 'z')
        int[] firstIndex = new int[26];
        Arrays.fill(firstIndex, -1);
        
        int maxGap = -1;
        
        for (int i = 0; i < s.length(); i++) {
            char ch = s.charAt(i);
            int charIdx = ch - 'a';
            
            // If the character has been seen before, calculate the gap
            if (firstIndex[charIdx] != -1) {
                int gap = i - firstIndex[charIdx] - 1;
                maxGap = Math.max(maxGap, gap);
            } else {
                // Store the first occurrence index
                firstIndex[charIdx] = i;
            }
        }
        
        return maxGap;
    }
}
