import java.io.*;
import java.util.*;

public class Solution {

    public static void main(String[] args) {
        Scanner in = new Scanner(System.in);
        int t = in.nextInt();
        
        for (int a0 = 0; a0 < t; a0++) {
            int n = in.nextInt();
            System.out.println(getSmallestMultiple(n));
        }
        in.close();
    }
    
    // Method to calculate the LCM of numbers from 1 to N
    private static long getSmallestMultiple(int n) {
        long lcm = 1;
        for (int i = 1; i <= n; i++) {
            lcm = lcm(lcm, i);
        }
        return lcm;
    }
    
    // Helper method to calculate LCM of two numbers
    private static long lcm(long a, long b) {
        return (a * b) / gcd(a, b);
    }
    
    // Helper method to calculate GCD using Euclidean Algorithm
    private static long gcd(long a, long b) {
        while (b != 0) {
            long temp = b;
            b = a % b;
            a = temp;
        }
        return a;
    }
}
