import java.util.*;

public class Main {
    public static int sumOfDepths(int n, List<int[]> edges) {
        // Handle edge case where there's only 1 node
        if (n <= 1) {
            return 0;
        }

        // Step 1: Build the adjacency list for the tree
        List<List<Integer>> adj = new ArrayList<>();
        for (int i = 0; i <= n; i++) {
            adj.add(new ArrayList<>());
        }

        for (int[] edge : edges) {
            int u = edge[0];
            int v = edge[1];
            adj.get(u).add(v);
            adj.get(v).add(u);
        }

        // Step 2: Use BFS to calculate the depth of each node from root '1'
        // We track the sum using a long variable to prevent intermediate overflow
        long totalDepthSum = 0;

        // Queue stores elements as an array: {node_id, depth_of_node}
        Queue<int[]> queue = new LinkedList<>();
        boolean[] visited = new boolean[n + 1];

        // Initialize BFS with root node 1 at depth 0
        queue.add(new int[]{1, 0});
        visited[1] = true;

        while (!queue.isEmpty()) {
            int[] current = queue.poll();
            int node = current[0];
            int depth = current[1];

            // Add current node's depth to the running sum
            totalDepthSum += depth;

            // Traverse all unvisited neighboring child nodes
            for (int neighbor : adj.get(node)) {
                if (!visited[neighbor]) {
                    visited[neighbor] = true;
                    queue.add(new int[]{neighbor, depth + 1});
                }
            }
        }

        // Cast back to int to strictly match the platform's template signature
        return (int) totalDepthSum;
    }

    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);
        if (scanner.hasNextInt()) {
            int n = scanner.nextInt();
            List<int[]> edges = new ArrayList<>();
            for (int i = 0; i < n - 1; ++i) {
                int a = scanner.nextInt();
                int b = scanner.nextInt();
                edges.add(new int[]{a, b});
            }
            int result = sumOfDepths(n, edges);
            System.out.println(result);
        }
        scanner.close();
    }
}
